                <div style="background: #ecfdf5; color: #065f46; padding: 1rem; border-radius: 12px; border: 1px solid #a7f3d0; margin-bottom: 2rem; display: flex; align-items: center; gap: 10px;">
                    <i class="fas fa-circle-check"></i> {{ session('success') }}
                </div>
