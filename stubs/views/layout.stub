<!DOCTYPE html>
<html lang="{{ str_replace('_', '-', app()->getLocale()) }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ __('RBAC Premium Dashboard') }}</title>
    <!-- Modern Typography -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <!-- FontAwesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <style>
        :root {
            /* Primary Brand */
            --primary-rgb: 67, 56, 202;
            --primary: rgb(var(--primary-rgb));
            --primary-hover: #3730a3;
            --primary-soft: rgba(var(--primary-rgb), 0.1);
            
            /* Backgrounds */
            --bg-body: #f8fafc;
            --bg-sidebar: #ffffff;
            --bg-card: #ffffff;
            --bg-topbar: rgba(255, 255, 255, 0.8);
            
            /* Text Colors */
            --text-main: #1e293b;
            --text-muted: #64748b;
            
            /* Status Colors */
            --success-rgb: 16, 185, 129;
            --success: rgb(var(--success-rgb));
            --success-soft: rgba(var(--success-rgb), 0.1);
            
            --danger-rgb: 239, 68, 68;
            --danger: rgb(var(--danger-rgb));
            --danger-soft: rgba(var(--danger-rgb), 0.1);
            
            --warning-rgb: 245, 158, 11;
            --warning: rgb(var(--warning-rgb));
            --warning-soft: rgba(var(--warning-rgb), 0.1);
            
            --info-rgb: 14, 165, 233;
            --info: rgb(var(--info-rgb));
            --info-soft: rgba(var(--info-rgb), 0.1);
            
            /* Borders */
            --border: #e2e8f0;
            --border-light: #f1f5f9;
            
            /* Effects */
            --shadow-sm: 0 1px 2px 0 rgb(0 0 0 / 0.05);
            --shadow-md: 0 4px 6px -1px rgb(0 0 0 / 0.1);
            --shadow-lg: 0 10px 15px -3px rgb(0 0 0 / 0.1);
            --glass-blur: blur(12px);
            
            /* Sizes */
            --radius-sm: 0.375rem;
            --radius-md: 0.75rem;
            --radius-lg: 1.25rem;
            --sidebar-width: 280px;
            --topbar-height: 75px;
            --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        [data-theme="dark"] {
            --primary-rgb: 129, 140, 248;
            --bg-body: #0f172a;
            --bg-sidebar: #1e293b;
            --bg-card: #1e293b;
            --bg-topbar: rgba(15, 23, 42, 0.8);
            --text-main: #f1f5f9;
            --text-muted: #94a3b8;
            --border: #334155;
            --border-light: #1e293b;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }
        
        body { 
            font-family: 'Outfit', sans-serif; 
            background-color: var(--bg-body); 
            color: var(--text-main); 
            display: flex; 
            overflow-x: hidden; 
            -webkit-font-smoothing: antialiased;
        }

        /* ====== SIDEBAR ====== */
        .sidebar {
            width: var(--sidebar-width);
            height: 100vh;
            background: var(--bg-sidebar);
            border-right: 1px solid var(--border);
            position: fixed;
            transition: var(--transition);
            z-index: 1000;
            display: flex;
            flex-direction: column;
        }

        .sidebar-header {
            height: var(--topbar-height);
            padding: 0 1.5rem;
            display: flex;
            align-items: center;
            gap: 12px;
            font-size: 1.5rem;
            font-weight: 800;
            color: var(--primary);
            border-bottom: 1px solid var(--border-light);
        }
        
        .sidebar-header .logo-icon {
            background: var(--primary-soft);
            color: var(--primary);
            width: 42px;
            height: 42px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 12px;
        }

        .sidebar-menu { flex: 1; padding: 1.5rem 1rem; overflow-y: auto; }
        .menu-label { font-size: 0.7rem; text-transform: uppercase; color: var(--text-muted); margin: 1.5rem 0 0.75rem 0.75rem; font-weight: 700; opacity: 0.7; }

        .nav-link {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 0.8rem 1rem;
            color: var(--text-main);
            text-decoration: none;
            border-radius: var(--radius-md);
            font-weight: 500;
            transition: var(--transition);
            margin-bottom: 4px;
        }

        .nav-link:hover, .nav-link.active { background: var(--primary-soft); color: var(--primary); }
        .nav-link.active { font-weight: 600; box-shadow: inset 4px 0 0 var(--primary); }
        .nav-link i { font-size: 1.1rem; width: 24px; text-align: center; color: var(--text-muted); }

        .sync-box {
            background: linear-gradient(135deg, var(--primary) 0%, var(--primary-hover) 100%);
            padding: 1.5rem; border-radius: var(--radius-md); margin: 1.5rem; color: white; text-align: center;
        }

        /* ====== MAIN CONTENT ====== */
        .wrapper { margin-left: var(--sidebar-width); width: calc(100% - var(--sidebar-width)); display: flex; flex-direction: column; min-height: 100vh; transition: var(--transition); }

        /* Topbar */
        .topbar {
            height: var(--topbar-height);
            background: var(--bg-topbar);
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 2rem;
            position: sticky; top: 0; z-index: 999;
            backdrop-filter: var(--glass-blur);
        }

        .mobile-toggle { display: none; background: none; border: none; font-size: 1.5rem; color: var(--text-main); cursor: pointer; }

        .search-box {
            display: flex; align-items: center; background: var(--bg-body); padding: 10px 18px; border-radius: 30px; width: 350px; border: 1px solid var(--border); transition: var(--transition);
        }
        .search-box input { border: none; background: none; outline: none; padding-left: 10px; width: 100%; color: inherit; }

        .profile-section { display: flex; align-items: center; gap: 12px; cursor: pointer; position: relative; padding: 6px 12px; border-radius: 40px; transition: var(--transition); }
        .profile-section:hover { background: var(--border-light); }
        .profile-img { width: 40px; height: 40px; border-radius: 50%; object-fit: cover; border: 2px solid var(--primary-soft); }

        /* Profile Dropdown */
        .profile-dropdown {
            position: absolute; top: calc(100% + 10px); right: 0; width: 240px; background: var(--bg-card); border-radius: var(--radius-md);
            box-shadow: var(--shadow-lg); border: 1px solid var(--border); display: none; flex-direction: column; overflow: hidden;
            animation: fadeIn 0.3s ease;
        }
        .profile-section.active .profile-dropdown { display: flex; }
        .dropdown-item { padding: 14px 18px; display: flex; align-items: center; gap: 12px; color: var(--text-main); text-decoration: none; font-size: 0.9rem; transition: background 0.2s; }
        .dropdown-item:hover { background: var(--border-light); color: var(--primary); }

        .main-content { padding: 2.5rem; flex: 1; }

        /* ====== RESPONSIVE DESIGN ====== */
        @media (max-width: 1100px) {
            .sidebar { transform: translateX(-100%); }
            .sidebar.active { transform: translateX(0); box-shadow: var(--shadow-lg); }
            .wrapper { margin-left: 0; width: 100%; }
            .mobile-toggle { display: block; margin-right: 15px; }
            .search-box { width: 250px; }
        }

        @media (max-width: 768px) {
            .main-content { padding: 1.5rem; }
            .topbar { padding: 0 1rem; }
            .search-box { display: none; }
            .profile-info { display: none; }
            
            /* Grid Helpers for stubs */
            .grid-2-col { grid-template-columns: 1fr !important; }
            .grid-3-col { grid-template-columns: 1fr !important; }
            .grid-4-col { grid-template-columns: 1fr !important; }
            
            .card { padding: 1.25rem !important; }
        }

        @media (max-width: 480px) {
            .topbar-actions { gap: 0.5rem !important; }
            .lang-pill { padding: 4px 8px !important; font-size: 0.7rem !important; }
            .profile-section { padding: 4px; }
            .profile-img { width: 35px; height: 35px; }
        }

        /* Shared Components */
        .card { background: var(--bg-card); border-radius: var(--radius-md); padding: 1.75rem; box-shadow: var(--shadow-sm); border: 1px solid var(--border); margin-bottom: 1.5rem; }
        .card-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; padding-bottom: 1rem; border-bottom: 1px solid var(--border-light); flex-wrap: wrap; gap: 10px; }
        .card-title { font-size: 1.25rem; font-weight: 700; color: var(--text-main); }

        .btn { padding: 0.75rem 1.5rem; border-radius: var(--radius-sm); font-weight: 600; cursor: pointer; border: none; display: inline-flex; align-items: center; justify-content: center; gap: 8px; text-decoration: none; font-size: 0.9rem; transition: var(--transition); }
        .btn-primary { background: var(--primary); color: white; }
        .btn-primary:hover { background: var(--primary-hover); transform: translateY(-1px); }
        .btn-outline { background: transparent; color: var(--text-main); border: 1.5px solid var(--border); }
        .btn-outline:hover { background: var(--border-light); }
        
        .table-responsive { overflow-x: auto; -webkit-overflow-scrolling: touch; }
        .table { width: 100%; border-collapse: collapse; min-width: 600px; }
        .table th { text-align: left; padding: 1rem; font-size: 0.75rem; text-transform: uppercase; color: var(--text-muted); background: var(--border-light); }
        .table td { padding: 1rem; border-bottom: 1px solid var(--border-light); }

        .badge { padding: 0.35rem 0.85rem; border-radius: 30px; font-size: 0.75rem; font-weight: 700; display: inline-flex; align-items: center; gap: 4px; }
        .badge-primary { background: var(--primary-soft); color: var(--primary); }
        .badge-success { background: var(--success-soft); color: var(--success); }

        .form-control { width: 100%; padding: 0.875rem 1.125rem; border-radius: var(--radius-sm); border: 1.5px solid var(--border); background: var(--bg-body); color: var(--text-main); font-family: inherit; transition: var(--transition); }
        .form-control:focus { outline: none; border-color: var(--primary); box-shadow: 0 0 0 4px var(--primary-soft); }

        @keyframes fadeIn { from { opacity: 0; transform: translateY(-5px); } to { opacity: 1; transform: translateY(0); } }
    </style>
</head>
<body>

    <div id="sidebarOverlay" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.4); z-index: 999;" onclick="toggleSidebar()"></div>

    <aside class="sidebar" id="sidebar">
