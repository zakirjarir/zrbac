            </div>

            <div class="topbar-actions" style="display: flex; align-items: center; gap: 1rem;">
                <!-- Theme -->
                <button onclick="toggleTheme()" style="background: var(--border-light); border: none; width: 38px; height: 38px; border-radius: 50%; color: var(--text-main); cursor: pointer; display: flex; align-items: center; justify-content: center;">
                    <i class="fas fa-moon" id="theme-icon"></i>
                </button>

                <!-- Profile -->
                <div class="profile-section" onclick="this.classList.toggle('active')">
